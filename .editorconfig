# EditorConfig — foo_ui_webview2
# https://editorconfig.org

root = true

# ---------- 全局默认 ----------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ---------- C++ 源码 ----------
[*.{cpp,h,hpp,c,cc,cxx,hxx,inl,rc}]
indent_style = tab
tab_width = 4
end_of_line = crlf

# ---------- 项目文件 / XML ----------
[*.{vcxproj,vcxproj.filters,props,targets,config,xml}]
indent_style = space
indent_size = 2
end_of_line = crlf

# ---------- JavaScript / TypeScript ----------
[*.{js,ts,mjs,cjs,mts,cts,jsx,tsx}]
indent_style = space
indent_size = 2

# ---------- JSON / YAML ----------
[*.{json,jsonc,yaml,yml}]
indent_style = space
indent_size = 2

# ---------- HTML / CSS / Vue ----------
[*.{html,htm,css,scss,less,vue,svelte}]
indent_style = space
indent_size = 2

# ---------- PowerShell ----------
[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8-bom

# ---------- Markdown ----------
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ---------- Makefile ----------
[Makefile]
indent_style = tab

# ---------- Batch / CMD ----------
[*.{bat,cmd}]
end_of_line = crlf

# ---------- Properties ----------
[*.properties]
indent_style = space
indent_size = 2
